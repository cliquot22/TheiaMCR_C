{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (vcpkg)",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "python",
      "displayName": "With Python bindings",
      "inherits": "default",
      "cacheVariables": {
        "ENABLE_PYTHON_BINDINGS": "ON"
      }
    }
  ]
}